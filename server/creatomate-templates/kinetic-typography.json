          "width": "80%",
          "height": "auto",
          "x": "50%",
          "y": "50%",
          "animations": [
            {
              "time": 0,
              "duration": 0.8,
              "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)",
              "type": "text-slide",
              "scope": "word",
              "split_delay": 0.05,
              "direction": "right"
            }
          ]
        }
      ]
