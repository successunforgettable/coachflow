{
  "output_format": "mp4",
  "width": 1080,
  "height": 1080,
  "duration": null,
  "elements": [
    {
      "type": "image",
      "name": "Logo",
      "source": "{{logo_url}}",
      "width": "15%",
      "height": "15%",
      "x": "10%",
      "y": "10%",
      "duration": null
    },
    {
      "type": "audio",
      "name": "Voiceover",
      "source": "{{voiceover_url}}",
      "duration": null
    },
    {
      "type": "composition",
      "name": "Scene1",
      "time": 0,
      "duration": null,
      "elements": [
        {
          "type": "text",
          "name": "Scene1Text",
          "text": "{{scene_1_text}}",
          "fill_color": "{{brand_color}}",
          "font_family": "Montserrat",
          "font_weight": 700,
          "font_size": null,
          "font_size_minimum": "4 vmin",
          "font_size_maximum": "10 vmin",
          "x_alignment": "50%",
          "y_alignment": "50%",
          "text_transform": "uppercase",
          "width": "80%",
          "height": "auto",
          "x": "50%",
          "y": "50%",
          "animations": [
            {
              "time": 0,
              "duration": 0.8,
              "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)",
              "type": "text-slide",
              "scope": "word",
              "split_delay": 0.05,
              "direction": "left"
            }
          ]
        }
      ]
    },
    {
      "type": "composition",
      "name": "Scene2",
      "time": null,
